{
  "name": "minimal-map",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "description": "Minimal WordPress-native map plugin.",
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "build": "bun run build:bundle && bun run build:check",
    "build:bundle": "wp-scripts build",
    "build:check": "node ./bin/check-bundle-budgets.mjs",
    "build:stats": "mkdir -p reports && wp-scripts build --profile --json > reports/bundle-stats.json",
    "build:analyze": "bun run build:stats && node ./bin/create-bundle-report.mjs",
    "build:dev": "wp-scripts start --no-watch",
    "i18n:pot:php": "wp i18n make-pot . /tmp/minimal-map-php.pot --domain=minimal-map --exclude=node_modules,build,.git,languages --skip-block-json",
    "i18n:pot:js": "node ./bin/make-js-pot.mjs /tmp/minimal-map-js.pot",
    "i18n:pot": "npm run i18n:pot:php && npm run i18n:pot:js && msgcat --use-first /tmp/minimal-map-php.pot /tmp/minimal-map-js.pot -o languages/minimal-map.pot",
    "i18n:mo": "wp i18n make-mo languages languages",
    "i18n:json": "node ./bin/make-script-json.mjs",
    "i18n": "npm run i18n:pot && npm run i18n:mo && npm run i18n:json",
    "start": "wp-scripts start",
    "start:hot": "wp-scripts start --hot",
    "dev": "wp-scripts start",
    "dev:hot": "wp-scripts start --hot"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wordpress/api-fetch": "^7.41.0",
    "@wordpress/block-editor": "^15.14.0",
    "@wordpress/blocks": "^15.14.0",
    "@wordpress/components": "^32.3.0",
    "@wordpress/dataviews": "^13.0.0",
    "@wordpress/dom-ready": "^4.41.0",
    "@wordpress/i18n": "^6.14.0",
    "@wordpress/scripts": "^30.18.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.3.0"
  }
}
